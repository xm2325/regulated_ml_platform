FROM python:3.11-slim

ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /workspace
COPY requirements-runtime.lock requirements-mlflow.lock ./
RUN python -m pip install --no-cache-dir -r requirements-runtime.lock -r requirements-mlflow.lock
COPY src ./src
ENTRYPOINT ["python", "-m", "src.registry.cli"]
