{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "id": 1,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true}},
      "targets": [
        {
          "expr": "sum by (service) (rate(regulated_ai_http_requests_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "Request rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"max": 1, "min": 0, "unit": "percentunit", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.01}]}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true}},
      "targets": [
        {
          "expr": "sum by (service) (rate(regulated_ai_http_requests_total{namespace=~\"$namespace\",status=~\"5..\"}[5m])) / clamp_min(sum by (service) (rate(regulated_ai_http_requests_total{namespace=~\"$namespace\"}[5m])), 0.001)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "Error rate (rollback at 1%)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "ms", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 250}]}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "id": 3,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true}},
      "targets": [
        {
          "expr": "1000 * histogram_quantile(0.95, sum by (service, le) (rate(regulated_ai_http_request_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "p95 API latency (rollback at 250 ms)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"min": 0, "max": 1, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 8},
      "id": 4,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [
        {
          "expr": "max by (name, phase) (rollout_info{namespace=~\"$namespace\"})",
          "legendFormat": "{{name}} {{phase}}",
          "refId": "A"
        }
      ],
      "title": "Argo Rollout phase",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"min": 0, "unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.2}]}}, "overrides": []},
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 8},
      "id": 5,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true}},
      "targets": [
        {"expr": "max by (model_version) (model_drift_psi{namespace=~\"$namespace\"})", "legendFormat": "{{model_version}}", "refId": "A"}
      ],
      "title": "Population Stability Index",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"min": 0, "unit": "percentunit", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.1}]}}, "overrides": []},
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 8},
      "id": 6,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true}},
      "targets": [
        {"expr": "max by (model_version, protected_attribute) (model_fairness_gap{namespace=~\"$namespace\"})", "legendFormat": "{{model_version}} {{protected_attribute}}", "refId": "A"}
      ],
      "title": "Fairness gap",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ms"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 15},
      "id": 7,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true}},
      "targets": [
        {
          "expr": "sum by (model) (rate(nv_inference_queue_duration_us{namespace=~\"$namespace\"}[5m])) / clamp_min(sum by (model) (rate(nv_inference_request_success{namespace=~\"$namespace\"}[5m])), 0.001) / 1000",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Triton mean queue latency",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"max": 100, "min": 0, "unit": "percent"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 15},
      "id": 8,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true}},
      "targets": [
        {"expr": "avg by (pod, gpu) (DCGM_FI_DEV_GPU_UTIL{namespace=~\"$namespace\"})", "legendFormat": "{{pod}} GPU {{gpu}}", "refId": "A"}
      ],
      "title": "A100 GPU utilisation",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["regulated-ai", "argo-rollouts", "triton", "gpu"],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": {"selected": true, "text": "All", "value": "$__all"},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "definition": "label_values(up, namespace)",
        "hide": 0,
        "includeAll": true,
        "label": "Namespace",
        "multi": true,
        "name": "namespace",
        "options": [],
        "query": {"query": "label_values(up, namespace)", "refId": "StandardVariableQuery"},
        "refresh": 1,
        "regex": "/regulated-ml-.*/",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Regulated AI progressive delivery",
  "uid": "regulated-ai-progressive-delivery",
  "version": 1,
